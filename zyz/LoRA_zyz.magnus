# Magnus Blueprint: LoRA_zyz
# LoRA / QLoRA SFT 训练（低资源微调 72B 等大模型）
# 蓝图 ID = 文件名（约定所有 .magnus 以 _zyz 结尾）
# pip: --no-index 优先本地缓存, 清华源回退

from typing import Annotated, Optional, Literal

# ── 参数类型定义 ─────────────────────────────────────────────

ModelPath = Annotated[str, {
    "label": "模型路径",
    "description": "集群本地路径（优先）或 HuggingFace/ModelScope Hub ID",
    "placeholder": "/data/magnus/models/Qwen2.5-72B-Instruct",
    "allow_empty": False,
}]

TrainData = Annotated[Optional[str], {
    "label": "训练集路径（可选）",
    "description": "留空 = 自动生成30条假数据（用于验证流程）；填路径 = 使用真实数据训练",
    "placeholder": "留空=假数据 / /data/magnus/training_data/train.json",
}]

TestData = Annotated[Optional[str], {
    "label": "测试集路径（可选）",
    "description": "填路径 = 训练完成后自动评估；留空则跳过",
    "placeholder": "/data/magnus/training_data/test.json",
}]

OutputDir = Annotated[str, {
    "label": "输出目录",
    "description": (
        "必须填写 /data/magnus/models/ 下的子目录（持久存储，作业结束后不会消失）。"
        "保存 LoRA adapter（较小）和可选合并后的完整模型"
    ),
    "placeholder": "/data/magnus/models/qwen-lora-v1",
    "allow_empty": False,
}]

Epochs = Annotated[int, {
    "label": "训练轮数",
    "scope": "超参数",
    "min": 1,
    "max": 20,
    "default": 3,
}]

BatchSize = Annotated[int, {
    "label": "单卡 Batch Size",
    "scope": "超参数",
    "description": "每张 GPU 每步实际处理的样本数。LoRA 显存占用大幅降低，可适当增大",
    "min": 1,
    "max": 128,
    "default": 4,
}]

GradAccum = Annotated[int, {
    "label": "梯度累积步数",
    "scope": "超参数",
    "description": "等效全局 batch = 单卡 batch × 梯度累积 × GPU 数",
    "min": 1,
    "max": 32,
    "default": 4,
}]

LearningRate = Annotated[Optional[float], {
    "label": "学习率",
    "scope": "超参数",
    "description": "LoRA 通常比全参微调学习率大 1-2 倍",
    "min": 1e-6,
    "max": 1e-3,
    "placeholder": "默认 5e-5",
    "default": 5e-5,
}]

MaxLength = Annotated[int, {
    "label": "最大序列长度（token）",
    "scope": "超参数",
    "min": 128,
    "max": 4096,
    "default": 1024,
}]

# ── LoRA 专属参数 ──────────────────────────────────────────

LoraR = Annotated[int, {
    "label": "LoRA Rank (r)",
    "scope": "超参数",
    "description": "rank 越大，可学习参数量越多，但显存也越大。QLoRA 论文推荐 64-256",
    "min": 4,
    "max": 512,
    "default": 64,
}]

LoraAlpha = Annotated[int, {
    "label": "LoRA Alpha",
    "scope": "超参数",
    "description": "缩放系数，通常设为 2×rank（如 r=64 时 alpha=128）",
    "min": 8,
    "max": 1024,
    "default": 128,
}]

LoraDropout = Annotated[float, {
    "label": "LoRA Dropout",
    "scope": "超参数",
    "min": 0.0,
    "max": 0.5,
    "default": 0.05,
}]

Quantization = Annotated[Literal["4bit", "8bit", "none"], {
    "label": "量化精度",
    "scope": "超参数",
    "description": "4bit=QLoRA（最省显存）, 8bit=折中, none=bf16 LoRA（最高精度但显存大）",
    "options": {
        "4bit": "QLoRA (4-bit NF4) — 72B 仅 ~36GB/卡，推荐",
        "8bit": "8-bit — 72B 约 ~72GB/卡，4卡刚好",
        "none": "bf16 LoRA — 72B 约 ~144GB/卡，需 8+ 卡",
    },
    "default": "4bit",
}]

TargetModules = Annotated[Optional[str], {
    "label": "LoRA Target Modules",
    "description": "逗号分隔，留空自动检测（Qwen2/LLaMA 自动选 q_proj,k_proj,v_proj,o_proj）",
    "placeholder": "留空=自动 / q_proj,k_proj,v_proj,o_proj,gate_proj,up_proj,down_proj",
}]

MergeOnSave = Annotated[bool, {
    "label": "保存时合并 adapter → 完整模型",
    "description": "开启：保存完整模型（占用存储大）；关闭：仅保存 LoRA adapter 权重（几百 MB）",
    "default": True,
}]

GpuCount = Annotated[int, {
    "label": "GPU 数量",
    "description": "QLoRA (4-bit) 下 72B 用 1-4 卡均可",
    "min": 1,
    "max": 8,
    "default": 4,
}]

GpuType = Annotated[Literal["a100", "cpu"], {
    "label": "GPU 类型",
    "options": {
        "a100": "A100 计算卡",
        "cpu": "仅 CPU（调试用）",
    },
    "default": "a100",
}]

CpuCount = Annotated[int, {
    "label": "CPU 核心数",
    "min": 4,
    "max": 64,
    "default": 40,
}]

MemoryDemand = Annotated[str, {
    "label": "内存需求",
    "description": "带单位！QLoRA 可适当降低",
    "placeholder": "160G",
    "default": "160G",
}]

EphemeralStorage = Annotated[str, {
    "label": "临时存储",
    "description": "带单位！用于数据缓存和中间文件",
    "placeholder": "500G",
    "default": "500G",
}]

Priority = Annotated[Literal["A1", "A2", "B1", "B2"], {
    "label": "作业优先级",
    "options": {
        "A1": {"label": "A1 最高", "description": "不可抢占"},
        "A2": {"label": "A2 高（推荐）", "description": "不可抢占"},
        "B1": {"label": "B1 低", "description": "可被 A 类抢占"},
        "B2": {"label": "B2 最低", "description": "可被 A 类抢占"},
    },
    "default": "A2",
}]

ExecuteAction = Annotated[bool, {
    "label": "立即执行",
    "description": "关闭则仅生成配置，不提交作业",
    "default": True,
}]

Runner = Annotated[Optional[str], {
    "label": "Runner",
    "description": "留空使用默认",
    "placeholder": "leave empty for default",
}]

ContainerImage = Annotated[Optional[str], {
    "label": "容器镜像",
    "description": "自定义 Docker 镜像 URI (docker://registry/name:tag)。留空使用集群默认。",
    "placeholder": "docker://your-registry/lora-sft:latest",
}]

ResumeFrom = Annotated[Optional[str], {
    "label": "从 Checkpoint 恢复（可选）",
    "description": "填写上次中断的 checkpoint secret 或本地路径，留空则从头开始",
    "placeholder": "留空 = 从头训练",
}]

# ── LoRA 训练脚本 ─────────────────────────────────────────────

LORA_TRAIN_PY = r'''
import argparse
import json
import os
import time
import traceback
import math
from datetime import timedelta

def log(msg: str) -> None:
    print(f"[{time.strftime('%Y-%m-%d %H:%M:%S')}] {msg}", flush=True)

import torch
import torch.nn.functional as F
import torch.distributed as dist
from torch.utils.data import Dataset, DataLoader
from torch.utils.data.distributed import DistributedSampler
from transformers import (
    AutoConfig,
    AutoModelForCausalLM,
    AutoTokenizer,
    get_cosine_schedule_with_warmup,
)
from torch.optim import AdamW

# ── 兼容性补丁 ──
import transformers.modeling_utils
transformers.modeling_utils.check_torch_load_is_safe = lambda: None


def parse_args():
    p = argparse.ArgumentParser(description="LoRA SFT on Magnus")
    p.add_argument("--model_path",    type=str, required=True)
    p.add_argument("--train_data",    type=str, required=True)
    p.add_argument("--test_data",     type=str, default=None)
    p.add_argument("--output_dir",    type=str, default="/tmp/lora_output")
    p.add_argument("--epochs",        type=int,   default=3)
    p.add_argument("--batch_size",    type=int,   default=4)
    p.add_argument("--gradient_accumulation_steps", type=int, default=4)
    p.add_argument("--learning_rate", type=float, default=5e-5)
    p.add_argument("--max_length",    type=int,   default=1024)
    p.add_argument("--warmup_ratio",  type=float, default=0.05)
    p.add_argument("--weight_decay",  type=float, default=0.01)
    p.add_argument("--logging_steps", type=int,   default=10)
    p.add_argument("--resume_from_checkpoint", type=str, default=None)
    # LoRA 参数
    p.add_argument("--lora_r",        type=int,   default=64)
    p.add_argument("--lora_alpha",    type=int,   default=128)
    p.add_argument("--lora_dropout",  type=float, default=0.05)
    p.add_argument("--target_modules", type=str,  default=None)
    p.add_argument("--quantization",  type=str,   default="4bit")
    p.add_argument("--merge_on_save", type=int,   default=1)
    return p.parse_args()


def load_json_dataset(path: str) -> list:
    if path.endswith(".parquet"):
        import pandas as pd
        df = pd.read_parquet(path)
        data = df.to_dict(orient="records")
    elif os.path.isdir(path):
        try:
            from datasets import load_from_disk
            ds = load_from_disk(path)
            data = [row for row in ds]
        except Exception:
            import glob
            files = sorted(
                glob.glob(os.path.join(path, "**", "*.json"),  recursive=True) +
                glob.glob(os.path.join(path, "**", "*.jsonl"), recursive=True)
            )
            if not files:
                raise FileNotFoundError(f"目录 {path} 中无 .json/.jsonl 文件")
            data = []
            for fp in files:
                log(f"[数据] 读取文件：{fp}")
                with open(fp, "r", encoding="utf-8") as f:
                    raw = f.read().strip()
                if raw.startswith("["):
                    data.extend(json.loads(raw))
                else:
                    data.extend([json.loads(line) for line in raw.splitlines() if line.strip()])
    else:
        with open(path, "r", encoding="utf-8") as f:
            raw = f.read().strip()
        if raw.startswith("["):
            data = json.loads(raw)
        else:
            data = [json.loads(line) for line in raw.splitlines() if line.strip()]
    assert len(data) > 0, f"数据集为空：{path}"
    log(f"[数据] 从 {path} 加载 {len(data)} 条样本")
    return data


class SFTDataset(Dataset):
    def __init__(self, samples, tokenizer, max_length):
        self.samples    = samples
        self.tokenizer  = tokenizer
        self.max_length = max_length

    def __len__(self):
        return len(self.samples)

    def __getitem__(self, idx):
        item = self.samples[idx]
        instruction = item.get("instruction", "")
        extra_input = item.get("input", "")
        output      = item.get("output", "")
        user_content = instruction
        if extra_input:
            user_content += f"\n{extra_input}"

        messages = [
            {"role": "user", "content": user_content},
            {"role": "assistant", "content": output}
        ]
        full_prompt = self.tokenizer.apply_chat_template(
            messages, tokenize=False, add_generation_prompt=False
        )
        user_messages = [{"role": "user", "content": user_content}]
        user_prompt = self.tokenizer.apply_chat_template(
            user_messages, tokenize=False, add_generation_prompt=True
        )
        user_ids = self.tokenizer.encode(user_prompt, add_special_tokens=False)
        full_ids = self.tokenizer.encode(full_prompt, add_special_tokens=False)
        input_ids = full_ids[:self.max_length]
        labels = ([-100] * len(user_ids) + full_ids[len(user_ids):])[:self.max_length]
        return {
            "input_ids": torch.tensor(input_ids, dtype=torch.long),
            "labels":    torch.tensor(labels,    dtype=torch.long),
        }


def collate_fn(batch, pad_id):
    max_len = max(b["input_ids"].size(0) for b in batch)
    input_ids_list, labels_list, attn_list = [], [], []
    for b in batch:
        n   = b["input_ids"].size(0)
        pad = max_len - n
        input_ids_list.append(F.pad(b["input_ids"], (0, pad), value=pad_id))
        labels_list.append(F.pad(b["labels"],    (0, pad), value=-100))
        attn_list.append(torch.cat([torch.ones(n, dtype=torch.long), torch.zeros(pad, dtype=torch.long)]))
    return {
        "input_ids":      torch.stack(input_ids_list),
        "labels":         torch.stack(labels_list),
        "attention_mask": torch.stack(attn_list),
    }


def unwrap_model(model):
    if hasattr(model, "module"):
        return model.module
    return model


def save_lora_checkpoint(model, tokenizer, output_dir, step, meta, local_rank=0):
    """FSDP-safe：所有 rank 参与 state_dict gather，仅 rank 0 写盘。"""
    ckpt_path = os.path.join(output_dir, "checkpoint-latest")
    os.makedirs(ckpt_path, exist_ok=True)
    _FSDP = None
    try:
        from torch.distributed.fsdp import FullyShardedDataParallel as _FSDP
    except ImportError:
        pass
    if _FSDP is not None and isinstance(model, _FSDP):
        from torch.distributed.fsdp.api import StateDictType, FullStateDictConfig
        full_config = FullStateDictConfig(rank0_only=True, offload_to_cpu=True)
        with _FSDP.state_dict_type(model, StateDictType.FULL_STATE_DICT, full_config):
            state = model.state_dict()
            if local_rank == 0:
                model.save_pretrained(ckpt_path, state_dict=state)
                tokenizer.save_pretrained(ckpt_path)
                with open(os.path.join(ckpt_path, "checkpoint_meta.json"), "w", encoding="utf-8") as f:
                    json.dump(meta, f, ensure_ascii=False, indent=2)
                log(f"  [Checkpoint] LoRA adapter saved step={step} -> {ckpt_path} (覆盖)")
    else:
        if local_rank != 0:
            return
        model.save_pretrained(ckpt_path)
        tokenizer.save_pretrained(ckpt_path)
        with open(os.path.join(ckpt_path, "checkpoint_meta.json"), "w", encoding="utf-8") as f:
            json.dump(meta, f, ensure_ascii=False, indent=2)
        log(f"  [Checkpoint] LoRA adapter saved step={step} -> {ckpt_path} (覆盖)")


def save_final(model, tokenizer, output_dir, train_log, merge_on_save, local_rank=0):
    """FSDP-safe：所有 rank 参与 state_dict gather，仅 rank 0 写盘。"""
    adapter_path = os.path.join(output_dir, "lora_adapter")
    os.makedirs(adapter_path, exist_ok=True)
    _FSDP = None
    try:
        from torch.distributed.fsdp import FullyShardedDataParallel as _FSDP
    except ImportError:
        pass
    if _FSDP is not None and isinstance(model, _FSDP):
        from torch.distributed.fsdp.api import StateDictType, FullStateDictConfig
        full_config = FullStateDictConfig(rank0_only=True, offload_to_cpu=True)
        with _FSDP.state_dict_type(model, StateDictType.FULL_STATE_DICT, full_config):
            state = model.state_dict()
            if local_rank == 0:
                model.save_pretrained(adapter_path, state_dict=state)
                tokenizer.save_pretrained(adapter_path)
                log(f"[LoRA adapter] 已保存 -> {adapter_path}")
                if merge_on_save:
                    log("[合并] 开始合并 LoRA adapter → 完整模型...")
                    merged = model.merge_and_unload()
                    final_path = os.path.join(output_dir, "final")
                    os.makedirs(final_path, exist_ok=True)
                    merged.save_pretrained(final_path, max_shard_size="1800MB")
                    tokenizer.save_pretrained(final_path)
                    log(f"[最终模型] 已保存 -> {final_path}")
                log_path = os.path.join(output_dir, "training_log.json")
                with open(log_path, "w", encoding="utf-8") as f:
                    json.dump(train_log, f, ensure_ascii=False, indent=2)
                log(f"[训练日志] 已保存 -> {log_path}")
    else:
        if local_rank != 0:
            return
        model.save_pretrained(adapter_path)
        tokenizer.save_pretrained(adapter_path)
        log(f"[LoRA adapter] 已保存 -> {adapter_path}")
        if merge_on_save:
            log("[合并] 开始合并 LoRA adapter → 完整模型...")
            merged = model.merge_and_unload()
            final_path = os.path.join(output_dir, "final")
            os.makedirs(final_path, exist_ok=True)
            merged.save_pretrained(final_path, max_shard_size="1800MB")
            tokenizer.save_pretrained(final_path)
            log(f"[最终模型] 已保存 -> {final_path}")
        log_path = os.path.join(output_dir, "training_log.json")
        with open(log_path, "w", encoding="utf-8") as f:
            json.dump(train_log, f, ensure_ascii=False, indent=2)
        log(f"[训练日志] 已保存 -> {log_path}")


@torch.no_grad()
def evaluate(model, dataloader, device, n_gpu=1, local_rank=0):
    model.eval()
    total_loss, total_steps = 0.0, 0
    for batch in dataloader:
        input_ids = batch["input_ids"].to(device)
        labels    = batch["labels"].to(device)
        attn_mask = batch["attention_mask"].to(device)
        outputs   = model(input_ids=input_ids, attention_mask=attn_mask, labels=labels)
        total_loss  += outputs.loss.item()
        total_steps += 1
    if n_gpu > 1:
        loss_t = torch.tensor([total_loss], device=device)
        cnt_t  = torch.tensor([total_steps], device=device)
        dist.all_reduce(loss_t, op=dist.ReduceOp.SUM)
        dist.all_reduce(cnt_t,  op=dist.ReduceOp.SUM)
        total_loss = loss_t.item()
        total_steps = int(cnt_t.item())
    model.train()
    return total_loss / max(total_steps, 1)


def train():
    args   = parse_args()
    device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
    n_gpu  = torch.cuda.device_count()
    local_rank = 0
    if n_gpu > 1:
        local_rank = int(os.environ.get("LOCAL_RANK", 0))
        dist.init_process_group(backend="nccl", timeout=timedelta(seconds=1800))
        torch.cuda.set_device(local_rank)
        device = torch.device(f"cuda:{local_rank}")
    os.makedirs(args.output_dir, exist_ok=True)

    log(f"[环境] 设备={device}, GPU 数量={n_gpu}, rank={local_rank}")
    log(f"[配置] epochs={args.epochs}, batch_size={args.batch_size}, grad_accum={args.gradient_accumulation_steps}")
    log(f"[配置] lr={args.learning_rate}, max_length={args.max_length}")
    log(f"[配置] LoRA: r={args.lora_r}, alpha={args.lora_alpha}, dropout={args.lora_dropout}, quantization={args.quantization}")

    # ── Step 1: Tokenizer ──
    t0 = time.time()
    log(f"[1/8] 加载 tokenizer: {args.model_path}")
    tokenizer = AutoTokenizer.from_pretrained(args.model_path, trust_remote_code=True)
    if tokenizer.pad_token is None:
        tokenizer.pad_token = tokenizer.eos_token
    if tokenizer.chat_template is None:
        tokenizer.chat_template = "{% for message in messages %}{% if message['role'] == 'user' %}{{ 'User: ' + message['content'] + '\n\nAssistant: ' }}{% elif message['role'] == 'assistant' %}{{ message['content'] + '\n\n' }}{% endif %}{% endfor %}"
    log(f"[1/8] tokenizer 加载完成 ({time.time()-t0:.1f}s)")

    # ── Step 2: Config ──
    t0 = time.time()
    log(f"[2/8] 加载 config: {args.model_path}")
    config = AutoConfig.from_pretrained(args.model_path, trust_remote_code=True)
    log(f"[2/8] config 加载完成 ({time.time()-t0:.1f}s) | model_type={config.model_type}")

    # ── Step 3: 加载模型（支持量化）──
    log(f"[3/8] 开始加载模型...")
    load_kwargs = {
        "config": config,
        "trust_remote_code": True,
        "torch_dtype": torch.bfloat16 if torch.cuda.is_available() else torch.float32,
    }
    if args.quantization == "4bit":
        from transformers import BitsAndBytesConfig
        bnb_config = BitsAndBytesConfig(
            load_in_4bit=True,
            bnb_4bit_quant_type="nf4",
            bnb_4bit_compute_dtype=torch.bfloat16,
            bnb_4bit_use_double_quant=True,
        )
        load_kwargs["quantization_config"] = bnb_config
        log("[3/8] 量化: 4-bit NF4 (QLoRA)")
    elif args.quantization == "8bit":
        load_kwargs["load_in_8bit"] = True
        log("[3/8] 量化: 8-bit")
    else:
        log("[3/8] 量化: 无 (bf16 LoRA)")

    t0 = time.time()
    model = AutoModelForCausalLM.from_pretrained(args.model_path, **load_kwargs)
    log(f"[3/8] 模型加载完成 ({time.time()-t0:.1f}s)")
    if torch.cuda.is_available():
        for i in range(torch.cuda.device_count()):
            free, total = torch.cuda.mem_get_info(i)
            log(f"  GPU {i}: 空闲 {free/1e9:.1f}GB / 总计 {total/1e9:.1f}GB")

    _raw_params = sum(p.numel() for p in model.parameters())
    total_params = _raw_params / 1e9
    log(f"[参数量] 原始: {total_params:.2f}B")

    # ── Step 4: 配置 LoRA ──
    t0 = time.time()
    log(f"[4/8] 配置 LoRA...")
    from peft import LoraConfig, get_peft_model, TaskType

    # 自动检测 target_modules
    auto_targets = None
    if args.target_modules:
        auto_targets = [m.strip() for m in args.target_modules.split(",")]
    else:
        # Qwen2 标准模块名
        _arch = getattr(config, "architectures", [""])[0].lower() if getattr(config, "architectures", None) else ""
        if "qwen2" in _arch:
            auto_targets = ["q_proj", "k_proj", "v_proj", "o_proj"]
        elif "llama" in _arch:
            auto_targets = ["q_proj", "k_proj", "v_proj", "o_proj", "gate_proj", "up_proj", "down_proj"]
        else:
            auto_targets = ["q_proj", "k_proj", "v_proj", "o_proj"]
        log(f"[4/8] 自动检测 target_modules ({_arch}): {auto_targets}")

    lora_config = LoraConfig(
        task_type=TaskType.CAUSAL_LM,
        r=args.lora_r,
        lora_alpha=args.lora_alpha,
        lora_dropout=args.lora_dropout,
        target_modules=auto_targets,
    )
    model = get_peft_model(model, lora_config)

    # LoRA 可训练参数量
    lora_params = sum(p.numel() for p in model.parameters() if p.requires_grad)
    lora_params_b = lora_params / 1e9
    log(f"[4/8] LoRA 可训练参数量: {lora_params:,} ({lora_params_b:.4f}B / {lora_params_b*100/total_params:.4f}% of full)")

    # ── Step 5: 分布式 / Gradient Checkpointing ──
    log(f"[5/8] 训练优化...")
    if hasattr(model, "gradient_checkpointing_enable"):
        model.gradient_checkpointing_enable()
        model.config.use_cache = False
        log("[5/8] gradient_checkpointing 已开启")

    # QLoRA + 多卡：使用 DDP（每卡完整 base model + LoRA）
    if n_gpu > 1:
        if args.quantization != "none":
            # 量化模型不支持 FSDP，用 DDP
            log(f"[5/8] 量化模式下使用 DDP ({n_gpu} GPU)...")
            model = torch.nn.parallel.DistributedDataParallel(
                model, device_ids=[local_rank], output_device=local_rank
            )
            log("[5/8] DDP 初始化完成")
        else:
            # bf16 LoRA 可以用 FSDP
            log(f"[5/8] FSDP ({n_gpu} GPU)...")
            from torch.distributed.fsdp import FullyShardedDataParallel as FSDP
            from torch.distributed.fsdp import ShardingStrategy, MixedPrecision
            from torch.distributed.fsdp.wrap import transformer_auto_wrap_policy
            from functools import partial
            _layer_cls = None
            for _name, _mod in model.named_modules():
                _cn = type(_mod).__name__
                if 'Decoder' in _cn and 'Layer' in _cn:
                    _layer_cls = type(_mod)
                    log(f"[5/8] 检测到 transformer layer: {_cn}")
                    break
            if _layer_cls is None:
                from torch.distributed.fsdp.wrap import size_based_auto_wrap_policy
                _policy = partial(size_based_auto_wrap_policy, min_num_params=1e8)
            else:
                _policy = partial(transformer_auto_wrap_policy, transformer_layer_cls={_layer_cls})
            model = FSDP(
                model,
                sharding_strategy=ShardingStrategy.FULL_SHARD,
                auto_wrap_policy=_policy,
                mixed_precision=MixedPrecision(
                    param_dtype=torch.bfloat16,
                    reduce_dtype=torch.bfloat16,
                    buffer_dtype=torch.bfloat16,
                ),
                device_id=local_rank,
            )
            log("[5/8] FSDP 初始化完成")
    else:
        model = model.to(device)
        log(f"[5/8] 单卡模式")

    eff_batch = args.batch_size * args.gradient_accumulation_steps * max(n_gpu, 1)
    log(f"[配置] 等效全局batch={eff_batch} ({args.batch_size}/卡 × {args.gradient_accumulation_steps}累积 × {max(n_gpu,1)}GPU)")

    # ── Step 6: 数据 ──
    t0 = time.time()
    log(f"[6/8] 加载训练数据: {args.train_data}")
    pad_id = tokenizer.pad_token_id
    def _collate(b): return collate_fn(b, pad_id)
    train_samples = load_json_dataset(args.train_data)
    log(f"[6/8] 训练样本: {len(train_samples)} 条")
    train_dataset = SFTDataset(train_samples, tokenizer, args.max_length)
    train_sampler = DistributedSampler(train_dataset, rank=local_rank, shuffle=True) if n_gpu > 1 else None
    train_loader  = DataLoader(train_dataset, batch_size=args.batch_size, shuffle=(train_sampler is None), sampler=train_sampler, num_workers=0, collate_fn=_collate)
    log(f"[6/8] DataLoader: {len(train_loader)} batches/epoch")

    eval_loader = None
    if args.test_data and os.path.exists(args.test_data):
        log(f"[6/8] 加载测试数据: {args.test_data}")
        eval_samples = load_json_dataset(args.test_data)
        eval_dataset = SFTDataset(eval_samples, tokenizer, args.max_length)
        eval_loader  = DataLoader(eval_dataset, batch_size=args.batch_size, shuffle=False, num_workers=0, collate_fn=_collate)
        log(f"[6/8] 测试集: {len(eval_samples)} 条")
    log(f"[6/8] 数据准备完成 ({time.time()-t0:.1f}s)")

    # ── Step 7: Optimizer ──
    t0 = time.time()
    log(f"[7/8] 创建 optimizer (AdamW, lr={args.learning_rate})...")
    optimizer = AdamW(model.parameters(), lr=args.learning_rate, weight_decay=args.weight_decay)
    accum = args.gradient_accumulation_steps
    steps_per_epoch = (len(train_loader) + accum - 1) // accum
    total_steps = steps_per_epoch * args.epochs
    warmup_steps = int(total_steps * args.warmup_ratio)
    scheduler = get_cosine_schedule_with_warmup(optimizer, warmup_steps, total_steps)
    log(f"[7/8] 优化器就绪 ({time.time()-t0:.1f}s) | steps_per_epoch={steps_per_epoch} | total_steps={total_steps} | warmup={warmup_steps}")

    # ── Step 8: 训练 ──
    log(f"[8/8] 开始训练循环")
    log(f"{'='*60}")
    log(f"  模型: {total_params:.2f}B params | LoRA: {lora_params_b:.4f}B trainable")
    log(f"  数据: {len(train_samples)} 训练样本 | {len(train_loader)} batches/epoch")
    log(f"  训练: {args.epochs} epochs × {steps_per_epoch} steps = {total_steps} total steps")
    log(f"  保存: 每 40 steps（自动覆盖） | 日志: 每 {args.logging_steps} steps")
    log(f"  GPU: {n_gpu} × {torch.cuda.get_device_name(0) if torch.cuda.is_available() else 'CPU'}")
    log(f"{'='*60}")

    train_log   = []
    global_step = 0
    optimizer.zero_grad()
    model.train()

    # ── 诊断: 数据质量预检（仅 rank 0）──
    if local_rank == 0:
        bad_samples = 0
        for di, s in enumerate(train_dataset.samples):
            out = s.get("output", "")
            if not out or not out.strip():
                bad_samples += 1
                if bad_samples <= 3:
                    log(f"  [数据诊断] 空 output 样本 #{di}: instruction={s.get('instruction','')[:80]}")
        if bad_samples:
            log(f"  [数据诊断] 共 {bad_samples} 条空 output 样本（已统计）")
        else:
            log(f"  [数据诊断] 所有 {len(train_dataset.samples)} 条样本 output 均非空 ✓")

    for epoch in range(1, args.epochs + 1):
        if n_gpu > 1 and train_sampler is not None:
            train_sampler.set_epoch(epoch)
        epoch_loss  = 0.0
        nan_count   = 0
        _skip_count = 0
        epoch_start = time.time()
        slow_count  = 0
        torch.cuda.reset_peak_memory_stats()
        log(f"[Epoch {epoch}/{args.epochs}] 开始...")

        for step, batch in enumerate(train_loader, 1):
            step_start = time.time()

            # ── 诊断: 每 10 步打印一次步进信息 ──
            if local_rank == 0 and step % 10 == 1:
                log(f"  [诊断] >>> Step {step}/{len(train_loader)} (global {global_step+1}) 开始")

            input_ids = batch["input_ids"].to(device)
            labels    = batch["labels"].to(device)
            attn_mask = batch["attention_mask"].to(device)
            seq_len   = input_ids.shape[-1]

            # ── 诊断: 定期记录序列长度和显存 ──
            if local_rank == 0 and step % 40 == 1:
                cur_mem = torch.cuda.memory_allocated() / 1024**3
                peak_mem = torch.cuda.max_memory_allocated() / 1024**3
                log(f"  [诊断]   seq_len={seq_len}, GPU mem={cur_mem:.1f}GB (peak={peak_mem:.1f}GB)")

            # ── 前向传播（含异常恢复）──
            _skip_batch = False
            try:
                outputs = model(input_ids=input_ids, attention_mask=attn_mask, labels=labels)
                loss = outputs.loss
            except Exception as e:
                _skip_batch = True
                _skip_count += 1
                if local_rank == 0:
                    log(f"  [错误] Step {step} 前向异常: {e}")
                    for _tb_line in traceback.format_exc().rstrip().split("\n"):
                        log(f"  [错误]   {_tb_line}")

            if _skip_batch:
                loss = torch.zeros(1, device=device)

            if torch.isnan(loss) or torch.isinf(loss):
                nan_count += 1
                if local_rank == 0 and nan_count <= 5:
                    log(f"  [警告] NaN/Inf loss @ step {step}, 跳过此 batch (#{nan_count})")
                loss = torch.zeros_like(loss)

            try:
                (loss / accum).backward()
                epoch_loss += loss.item()
            except Exception as e:
                if local_rank == 0:
                    log(f"  [错误] Step {step} 反向异常: {e}")
                try:
                    (torch.zeros(1, device=device) / accum).backward()
                except:
                    pass

            # ── 诊断: 检测慢步 ──
            step_elapsed = time.time() - step_start
            if step_elapsed > 30:
                slow_count += 1
                log(f"  [SLOW] Step {step} 耗时 {step_elapsed:.1f}s | seq_len={seq_len} | "
                    f"GPU={torch.cuda.memory_allocated()/1024**3:.1f}GB "
                    f"(此 epoch 第 {slow_count} 次慢步)")
            elif step_elapsed > 10 and local_rank == 0:
                log(f"  [诊断] Step {step} 略慢: {step_elapsed:.1f}s | seq_len={seq_len}")

            is_update = (step % accum == 0) or (step == len(train_loader))
            if is_update:
                if hasattr(model, "clip_grad_norm_"):
                    model.clip_grad_norm_(1.0)
                else:
                    torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)
                optimizer.step()
                scheduler.step()
                optimizer.zero_grad()
                global_step += 1

                if global_step % args.logging_steps == 0:
                    avg_loss = epoch_loss / step
                    lr_now   = scheduler.get_last_lr()[0]
                    _free_gb = 0
                    if torch.cuda.is_available():
                        _free, _tot = torch.cuda.mem_get_info(device)
                        _free_gb = _free / 1e9
                    log(f"  Epoch {epoch}/{args.epochs} | Step {step}/{len(train_loader)} (global {global_step}) | Loss {avg_loss:.4f} | LR: {lr_now:.2e} | VRAM free: {_free_gb:.1f}GB")
                    train_log.append({"global_step": global_step, "epoch": round(epoch - 1 + step / len(train_loader), 3), "train_loss": round(avg_loss, 6), "lr": round(lr_now, 8), "vram_free_gb": round(_free_gb, 1), "timestamp": time.strftime("%Y-%m-%dT%H:%M:%S")})

                # ── 自动存档: 每 40 步覆盖保存 ──
                if global_step % 40 == 0:
                    eval_loss = evaluate(model, eval_loader, device, n_gpu, local_rank) if eval_loader else None
                    save_lora_checkpoint(model, tokenizer, args.output_dir, global_step, meta={"step": global_step, "epoch": round(epoch - 1 + step / len(train_loader), 3), "train_loss": round(epoch_loss / step, 6), "eval_loss": round(eval_loss, 6) if eval_loss is not None else None, "timestamp": time.strftime("%Y-%m-%dT%H:%M:%S")}, local_rank=local_rank)

        avg_epoch_loss = epoch_loss / len(train_loader)
        elapsed = time.time() - epoch_start
        eval_loss = evaluate(model, eval_loader, device, n_gpu, local_rank) if eval_loader else None
        eval_str = f" | Eval Loss: {eval_loss:.4f}" if eval_loss is not None else ""
        log(f"[Epoch {epoch}/{args.epochs}] Train Loss: {avg_epoch_loss:.4f}{eval_str} | 耗时: {elapsed:.0f}s ({elapsed/60:.1f}min)")
        if _skip_count > 0:
            log(f"  [诊断] Epoch {epoch} 中共 {_skip_count} 个 batch 因错误跳过")
        train_log.append({"global_step": global_step, "epoch": epoch, "train_loss": round(avg_epoch_loss, 6), "eval_loss": round(eval_loss, 6) if eval_loss is not None else None, "elapsed_sec": round(elapsed, 1), "timestamp": time.strftime("%Y-%m-%dT%H:%M:%S")})

    save_final(model, tokenizer, args.output_dir, train_log, merge_on_save=args.merge_on_save, local_rank=local_rank)

    final_eval_loss = evaluate(model, eval_loader, device, n_gpu, local_rank) if eval_loader else None
    result = {"status": "success", "final_train_loss": round(train_log[-1]["train_loss"], 6), "final_eval_loss": round(final_eval_loss, 6) if final_eval_loss is not None else None, "total_steps": global_step, "output_dir": args.output_dir}
    log(f"[结果] {json.dumps(result, ensure_ascii=False)}")
    return result

if __name__ == "__main__":
    train()
'''

# ── LoRA eval 推理脚本 ─────────────────────────────────────────
_EVAL_PY = """
import json, os, time
import torch
from transformers import AutoModelForCausalLM, AutoTokenizer
from peft import PeftModel
import transformers.modeling_utils
transformers.modeling_utils.check_torch_load_is_safe = lambda: None

def log(msg: str) -> None:
    print(f"[{time.strftime('%Y-%m-%d %H:%M:%S')}] {msg}", flush=True)

log("[推理] 加载基础模型: " + model_dir)
tokenizer = AutoTokenizer.from_pretrained(model_dir, trust_remote_code=True)
if tokenizer.pad_token is None:
    tokenizer.pad_token = tokenizer.eos_token
if tokenizer.chat_template is None:
    tokenizer.chat_template = "{% for message in messages %}{% if message['role'] == 'user' %}{{ 'User: ' + message['content'] + '\n\nAssistant: ' }}{% elif message['role'] == 'assistant' %}{{ message['content'] + '\n\n' }}{% endif %}{% endfor %}"

device = "cuda" if torch.cuda.is_available() else "cpu"
model = AutoModelForCausalLM.from_pretrained(
    model_dir,
    torch_dtype=torch.bfloat16 if device == "cuda" else torch.float32,
    device_map="auto" if device == "cuda" else None,
    trust_remote_code=True,
)
# 加载 LoRA adapter
adapter_path = os.path.join(model_dir, "lora_adapter")
if os.path.exists(adapter_path):
    log("[推理] 加载 LoRA adapter: " + adapter_path)
    model = PeftModel.from_pretrained(model, adapter_path)
    model = model.merge_and_unload()
    log("[推理] LoRA adapter 已合并")
else:
    log("[推理] 无 LoRA adapter，使用 base 模型直接推理")

if device == "cpu":
    model = model.to(device)
model.eval()
log("[推理] 模型加载完成，设备: " + device)

with open(test_path, "r", encoding="utf-8") as fh:
    raw = fh.read().strip()
samples = json.loads(raw) if raw.startswith("[") else [json.loads(ln) for ln in raw.splitlines() if ln.strip()]
log("[推理] 测试集共 " + str(len(samples)) + " 条")

results = []
for i, sample in enumerate(samples):
    instruction = sample.get("instruction", "")
    extra       = sample.get("input", "")
    gt_out      = sample.get("output", "")
    user_content = instruction + ("\\n" + extra if extra else "")
    messages = [{"role": "user", "content": user_content}]
    prompt = tokenizer.apply_chat_template(messages, tokenize=False, add_generation_prompt=True)
    inputs = tokenizer(prompt, return_tensors="pt", truncation=True, max_length=1024).to(device)
    with torch.no_grad():
        out_ids = model.generate(
            **inputs,
            max_new_tokens=512,
            do_sample=False,
            pad_token_id=tokenizer.eos_token_id,
        )
    new_ids  = out_ids[0][inputs["input_ids"].shape[1]:]
    response = tokenizer.decode(new_ids, skip_special_tokens=True).strip()
    results.append({
        "id":            sample.get("id", i),
        "question":      user_content,
        "gt_output":     gt_out,
        "full_response": response,
    })
    if (i + 1) % 10 == 0 or (i + 1) == len(samples):
        log("  进度 %d/%d" % (i + 1, len(samples)))

eval_dir = os.path.join(out_dir, "eval")
os.makedirs(eval_dir, exist_ok=True)
eval_path = os.path.join(eval_dir, "eval_results.json")
with open(eval_path, "w", encoding="utf-8") as fh:
    json.dump(results, fh, ensure_ascii=False, indent=2)
log("[推理] 结果已保存: " + eval_path + "  共 %d 条" % len(results))
"""


# ── Blueprint 主函数 ──────────────────────────────────────────
def blueprint(
    model_path:        ModelPath,
    train_data:        TrainData        = "/data/magnus/training_data/train.json",
    test_data:         TestData         = "/data/magnus/training_data/test.json",
    output_dir:        OutputDir        = "/data/magnus/models/qwen-lora-v1",
    epochs:            Epochs           = 3,
    batch_size:        BatchSize        = 4,
    grad_accum:        GradAccum        = 4,
    learning_rate:     LearningRate     = 5e-5,
    max_length:        MaxLength        = 1024,
    lora_r:            LoraR            = 64,
    lora_alpha:        LoraAlpha        = 128,
    lora_dropout:      LoraDropout      = 0.05,
    quantization:      Quantization     = "4bit",
    target_modules:    TargetModules    = None,
    merge_on_save:     MergeOnSave      = True,
    gpu_count:         GpuCount         = 4,
    gpu_type:          GpuType          = "a100",
    cpu_count:         CpuCount         = 40,
    memory_demand:     MemoryDemand     = "160G",
    ephemeral_storage: EphemeralStorage = "500G",
    priority:          Priority         = "A2",
    execute_action:    ExecuteAction    = True,
    runner:            Runner           = None,
    container_image:   ContainerImage   = None,
    resume_from:       ResumeFrom       = None,
):
    use_fake = not train_data
    model_name = model_path.split("/")[-1]
    ms_model_id = model_path[0].lower() + model_path[1:]

    # ── Resume 设置 ──
    def _is_magnus_secret(s):
        if not s:
            return False
        s = s.strip()
        if s.startswith("magnus-secret:"):
            return True
        parts = s.split("-")
        return len(parts) == 4 and parts[0].isdigit()

    if not resume_from:
        resume_setup = 'RESUME_ARG=""'
    elif _is_magnus_secret(resume_from):
        token = resume_from.strip()
        resume_setup = (
            '_log "=== [Resume] 从 Magnus 下载 checkpoint ==="\n'
            f'magnus receive {token} -o /tmp/resume_ckpt\n'
            'RESUME_ARG="--resume_from_checkpoint /tmp/resume_ckpt"\n'
            '_log "[Resume] checkpoint 已下载到 /tmp/resume_ckpt"'
        )
    else:
        resume_setup = f'RESUME_ARG="--resume_from_checkpoint {resume_from.strip()}"'

    # ── 模型加载 ──
    model_setup = f"""
_log "=== 加载模型 ==="
if [ -f "{model_path}/config.json" ]; then
    ACTUAL_MODEL_PATH="{model_path}"
    _log "[模型] 使用本地路径: $ACTUAL_MODEL_PATH"
    _log "[模型] 模型文件列表:"
    ls -lh "$ACTUAL_MODEL_PATH"/*.safetensors "$ACTUAL_MODEL_PATH"/*.bin "$ACTUAL_MODEL_PATH"/*.json 2>/dev/null | awk '{{printf "  %5s  %s\\n", $5, $NF}}'
    _log "[模型] 目录总大小: $(du -sh "$ACTUAL_MODEL_PATH" 2>/dev/null | cut -f1)"
else
    _log "[模型] 未找到: {model_path}/config.json"
    case "{model_path}" in
        /*)
            _log "[FATAL] 路径以 / 开头，是本地路径但不存在"
            exit 1
            ;;
        *)
            _log "[模型] Hub ID，尝试从 ModelScope 下载: {ms_model_id}"
            pip install -q modelscope -i https://pypi.tuna.tsinghua.edu.cn/simple
            if python3 -c "
from modelscope import snapshot_download
path = snapshot_download('{ms_model_id}', cache_dir='/tmp/models')
print(path)
" > /tmp/ms_path.txt 2>/tmp/ms_err.txt; then
                ACTUAL_MODEL_PATH=$(tail -1 /tmp/ms_path.txt)
                _log "[模型] ModelScope 完成: $ACTUAL_MODEL_PATH"
            else
                _log "[模型] ModelScope 失败，尝试 HuggingFace..."
                cat /tmp/ms_err.txt
                pip install -q huggingface-hub
                python3 -c "
from transformers import AutoModelForCausalLM, AutoTokenizer
import transformers.modeling_utils; transformers.modeling_utils.check_torch_load_is_safe = lambda: None
AutoTokenizer.from_pretrained('{model_path}', trust_remote_code=True).save_pretrained('/tmp/model_cache')
AutoModelForCausalLM.from_pretrained('{model_path}', trust_remote_code=True).save_pretrained('/tmp/model_cache')
print('HuggingFace 下载完成')
" 2>/tmp/hf_err.txt || { cat /tmp/hf_err.txt; exit 1; }
                ACTUAL_MODEL_PATH=/tmp/model_cache
            fi
            ;;
    esac
fi
"""

    # ── 数据设置 ──
    if use_fake:
        data_setup = """
_log "=== 生成假数据（30条通用测试题）==="
python3 -c "
import json
fake_train = [{'instruction': f'题目{i}：请计算 {i}+{i} 的结果。', 'output': f'答案：{i+i}\\n\\n解答：{i} 加 {i} 等于 {i+i}。'} for i in range(30)]
fake_test  = [{'instruction': f'测试题{i}：请计算 {i}×2 的结果。', 'output': f'答案：{i*2}\\n\\n解答：{i} 乘以 2 等于 {i*2}。'} for i in range(8)]
with open('/tmp/fake_train.json', 'w') as f: json.dump(fake_train, f, ensure_ascii=False)
with open('/tmp/fake_test.json',  'w') as f: json.dump(fake_test,  f, ensure_ascii=False)
print('假数据生成完成：train=30条，test=8条')
"
TRAIN_DATA_PATH=/tmp/fake_train.json
TEST_DATA_PATH=/tmp/fake_test.json
TRAIN_EPOCHS=1
TRAIN_BATCH=2
TRAIN_ACCUM=4
TRAIN_MAXLEN=256
TRAIN_LOG=5
"""
    else:
        data_setup = f"""
TRAIN_DATA_PATH="{train_data}"
TEST_DATA_PATH="{test_data if test_data else ''}"
TRAIN_EPOCHS={epochs}
TRAIN_BATCH={batch_size}
TRAIN_ACCUM={grad_accum}
TRAIN_MAXLEN={max_length}
TRAIN_LOG=10
"""

    # ── 评估 ──
    resolved_test = test_data if test_data else "/tmp/fake_test.json"
    eval_header = f"""
_log "=== [5/5] 测试集推理 ==="
cat > /tmp/eval_accuracy.py << 'PYEOF'
model_dir = "{output_dir}"
test_path  = "{resolved_test}"
out_dir    = "{output_dir}"
"""
    eval_custody = (
        f'\n_log "=== 上传推理结果 ==="\n'
        f'python3 << \'EVALEOF\'\n'
        f'import subprocess, sys\n'
        f'subprocess.run([sys.executable, "-m", "pip", "install", "-q", "magnus-sdk", "-i", "https://pypi.tuna.tsinghua.edu.cn/simple"], check=True)\n'
        f'import magnus\n'
        f'secret = magnus.custody_file("{output_dir}/eval/eval_results.json", expire_minutes=1440, timeout=60.0)\n'
        f'print("")\n'
        f'print("===== 推理结果下载命令 =====")\n'
        f'print(f"magnus receive {{secret}} -o ./eval_review/eval_results.json")\n'
        f'print("===========================")\n'
        f'EVALEOF\n'
    )
    eval_section = eval_header + _EVAL_PY + "\nPYEOF\npython3 /tmp/eval_accuracy.py\n" + eval_custody
    no_eval_section = '_log "[5/5] 未提供测试集，跳过评估"\n'

    # ── 汇总 ──
    result_section = f"""
python3 -c "
import json, os
log_path  = '{output_dir}/training_log.json'
eval_path = '{output_dir}/eval/eval_results.json'
last = {{}}
if os.path.exists(log_path):
    with open(log_path) as f:
        log = json.load(f)
    last = log[-1] if log else {{}}
eval_count = 0
if os.path.exists(eval_path):
    with open(eval_path) as f:
        ev = json.load(f)
    eval_count = len(ev) if isinstance(ev, list) else 0
print(json.dumps({{
    'status':           'success',
    'server_path':      '{output_dir}',
    'final_train_loss': last.get('train_loss'),
    'final_eval_loss':  last.get('eval_loss'),
    'eval_samples':     eval_count,
}}, ensure_ascii=False))
" > "$MAGNUS_RESULT"
"""

    # ── 组装 entry_command ──
    warmup_section = (
        '_log "=== [Warmup] 检查本地 pip 缓存 ===="\n'
        'USERNAME=$(whoami)\n'
        'WHEEL_DIR="/data/$USERNAME/pip-cache/wheels"\n'
        'if [ -d "$WHEEL_DIR" ] && ls "$WHEEL_DIR"/*.whl &>/dev/null 2>/dev/null; then\n'
        '    export PIP_FIND_LINKS="$WHEEL_DIR"\n'
        '    _log "[Warmup] 命中缓存: $WHEEL_DIR（$(ls "$WHEEL_DIR"/*.whl 2>/dev/null | wc -l) 个 wheel）"\n'
        'else\n'
        '    _log "[Warmup] 无本地缓存，使用清华镜像源"\n'
        'fi\n'
    )

    launcher = f"torchrun --nproc_per_node={gpu_count} --rdzv_endpoint=localhost:29501" if gpu_count > 1 else "python3"

    entry_command = (
        "set -e\n"
        "_log() { echo \"[$(date '+%Y-%m-%d %H:%M:%S')] $*\"; }\n"
        + warmup_section
        + "export PYTHONDONTWRITEBYTECODE=1\n"
        "export PYTHONUNBUFFERED=1\n"
        "export PYTHONPYCACHEPREFIX=/tmp/.pycache\n"
        "export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True\n"
        "# NCCL: 增加超时 + 避免 record stream hang\n"
        "export TORCH_NCCL_HEARTBEAT_TIMEOUT_SEC=1800\n"
        "export NCCL_DEBUG=WARN\n"
        "export TORCH_NCCL_AVOID_RECORD_STREAMS=1\n"
        "export NCCL_P2P_DISABLE=1\n"
        "export NCCL_IB_TIMEOUT=22\n"
        "export MASTER_PORT=29501\n\n"

        f'_on_exit() {{\n'
        f'    _log ""\n'
        f'    _log "=== [退出] 上传训练日志 ==="\n'
        f'    LOG_PATH="{output_dir}/training_log.json"\n'
        f'    if [ ! -f "$LOG_PATH" ]; then\n'
        f'        _log "[警告] 未找到训练日志: $LOG_PATH"\n'
        f'        return\n'
        f'    fi\n'
        f'    python3 << \'TRAPEOF\'\n'
        f'import subprocess, sys\n'
        f'subprocess.run([sys.executable, "-m", "pip", "install", "-q", "magnus-sdk", "-i", "https://pypi.tuna.tsinghua.edu.cn/simple"], check=True)\n'
        f'import magnus\n'
        f'secret = magnus.custody_file("{output_dir}/training_log.json", expire_minutes=1440, timeout=60.0)\n'
        f'print("")\n'
        f'print("===== 训练日志下载命令 =====")\n'
        f'print(f"magnus receive {{secret}} -o ./lora/training_log.json")\n'
        f'print("===========================")\n'
        f'TRAPEOF\n'
        f'}}\n'
        f'trap _on_exit EXIT\n\n'

        f'_log "=== [0/5] 检查输出目录 ==="\n'
        f'mkdir -p "{output_dir}" || {{\n'
        f'    _log "[FATAL] 无法创建输出目录 {output_dir}"\n'
        f'    exit 1\n'
        f'}}\n'
        f'_log "输出目录可用: {output_dir}"\n\n'

        f'_log "=== [1/5] 环境信息 ==="\n'
        "nvidia-smi\n"
        "python3 --version\n\n"

        # ── 依赖检查（增加 peft, bitsandbytes）──
        f'_log "=== [2/5] 检查依赖 ==="\n'
        "python3 - << 'DEPEOF'\n"
        "import os, sys, subprocess\n"
        "\n"
        "def ok(pkg, min_ver=None):\n"
        "    try:\n"
        "        m = __import__(pkg)\n"
        "        if min_ver:\n"
        "            cur = tuple(int(x) for x in m.__version__.split('.')[:2])\n"
        "            req = tuple(int(x) for x in min_ver.split('.')[:2])\n"
        "            return cur >= req\n"
        "        return True\n"
        "    except Exception:\n"
        "        return False\n"
        "\n"
        "checks = [\n"
        "    ('transformers',       'transformers',   None),\n"
        "    ('datasets',           'datasets',     None),\n"
        "    ('accelerate',         'accelerate',   None),\n"
        "    ('peft',               'peft',         None),\n"
        "    ('bitsandbytes',       'bitsandbytes', None),\n"
        "    ('pandas',             'pandas',       None),\n"
        "    ('einops',             'einops',       None),\n"
        "    ('sentencepiece',      'sentencepiece', None),\n"
        "    ('protobuf',           'google.protobuf', None),\n"
        "    ('scipy',              'scipy',        None),\n"
        "]\n"
        "need = []\n"
        "for spec, pkg, ver in checks:\n"
        "    if ok(pkg, ver):\n"
        "        m = __import__(pkg)\n"
        "        print(f'  [就绪] {pkg} {getattr(m, \"__version__\", \"\")}')\n"
        "    else:\n"
        "        need.append(spec)\n"
        "        print(f'  [缺失] {spec}')\n"
        "try:\n"
        "    import magnus; print('  [就绪] magnus (预装 SDK)')\n"
        "except ImportError:\n"
        "    print('  [警告] magnus SDK 未找到')\n"
        "\n"
        "if need:\n"
        "    print('安装缺失依赖:', ' '.join(need))\n"
        "    wheel_dir = os.environ.get('PIP_FIND_LINKS',\n"
        "        f'/data/{os.environ.get(\"USER\", \"magnus\")}/pip-cache/wheels')\n"
        "    base = [sys.executable, '-m', 'pip', 'install',\n"
        "        '--find-links', wheel_dir, '--progress-bar', 'on']\n"
        "    r = subprocess.run(base + ['--no-index'] + need)\n"
        "    if r.returncode != 0:\n"
        "        print('local cache miss, fallback to mirror...')\n"
        "        r = subprocess.run(base + ['-i', 'https://pypi.tuna.tsinghua.edu.cn/simple'] + need)\n"
        "    sys.exit(r.returncode)\n"
        "else:\n"
        "    print('所有依赖已就绪，跳过 pip install')\n"
        "DEPEOF\n"
        "python3 -c \"import torch; print('[环境] torch', torch.__version__, '| CUDA', torch.version.cuda, '| GPU', torch.cuda.device_count(), '张')\"\n\n"

        f'_log "=== [3/5] 准备模型和数据 ==="\n'
        + model_setup
        + data_setup
        + f'\n_log "=== [4/5] 开始 LoRA SFT 训练 ==="\n'
        + resume_setup + "\n\n"
        "cat > /tmp/lora_train.py << 'SFEOF'\n"
        + LORA_TRAIN_PY
        + "\nSFEOF\n\n"
        "# ── 训练前诊断 ──\n"
        f'_log "[诊断] launcher={launcher}"\n'
        f'_log "[诊断] ACTUAL_MODEL_PATH=$ACTUAL_MODEL_PATH"\n'
        f'_log "[诊断] TRAIN_DATA_PATH=$TRAIN_DATA_PATH"\n'
        f'_log "[诊断] TEST_DATA_PATH=$TEST_DATA_PATH"\n'
        f'_log "[诊断] CUDA_VISIBLE_DEVICES=${{CUDA_VISIBLE_DEVICES:-<未设置>}}"\n'
        "python3 -c \"import torch; print(f'[诊断] torch={torch.__version__}, cuda={torch.cuda.is_available()}, gpu_count={torch.cuda.device_count()}')\"\n"
        "# 验证 Python 脚本语法\n"
        "python3 -c \"compile(open('/tmp/lora_train.py').read(), '/tmp/lora_train.py', 'exec'); print('[诊断] lora_train.py 语法检查通过')\"\n"
        "# 测试关键 imports（在 torchrun 外预先检测 import 错误）\n"
        "python3 -c \"\n"
        "from transformers import AutoConfig, AutoModelForCausalLM, AutoTokenizer\n"
        "print('[诊断] transformers 核心导入 OK')\n"
        "\"\n"
        "TRAIN_OK=0\n"
        "TRAIN_EXIT_CODE=0\n"
        "TORCHRUN_LOG_DIR=/tmp/torchrun_logs_$$\n"
        "mkdir -p \"$TORCHRUN_LOG_DIR\"\n"
        f"if {launcher} \\\n"
        f'    --log-dir "$TORCHRUN_LOG_DIR" \\\n'
        f'    /tmp/lora_train.py \\\n'
        f'    --model_path    "$ACTUAL_MODEL_PATH" \\\n'
        f'    --train_data    "$TRAIN_DATA_PATH" \\\n'
        f'    --test_data     "$TEST_DATA_PATH" \\\n'
        f'    --output_dir    "{output_dir}" \\\n'
        f'    --epochs        $TRAIN_EPOCHS \\\n'
        f'    --batch_size    $TRAIN_BATCH \\\n'
        f'    --gradient_accumulation_steps $TRAIN_ACCUM \\\n'
        f'    --learning_rate {learning_rate} \\\n'
        f'    --max_length    $TRAIN_MAXLEN \\\n'
        f'    --logging_steps $TRAIN_LOG \\\n'
        f'    --lora_r        {lora_r} \\\n'
        f'    --lora_alpha    {lora_alpha} \\\n'
        f'    --lora_dropout  {lora_dropout} \\\n'
        f'    --quantization  {quantization} \\\n'
        f'    --merge_on_save {"1" if merge_on_save else "0"} \\\n'
        + (f'    --target_modules "{target_modules}" \\\n' if target_modules else '')
        + f'    $RESUME_ARG 2>&1; then\n'
        f'    TRAIN_OK=1\n'
        f'    _log "=== LoRA 训练完成 ==="\n'
        "else\n"
        '    TRAIN_EXIT_CODE=$?\n'
        f'    _log "[FATAL] LoRA 训练异常退出 (exit_code=$TRAIN_EXIT_CODE)"\n'
        f'    _log "[FATAL] torchrun 日志目录: $TORCHRUN_LOG_DIR"\n'
        f'    _log "[FATAL] === 各 rank 日志 ==="\n'
        f'    for f in "$TORCHRUN_LOG_DIR"/*; do\n'
        f'        if [ -f "$f" ]; then\n'
        f'            _log "--- $f ---"\n'
        f'            cat "$f"\n'
        f'            _log "--- end of $f ---"\n'
        f'        fi\n'
        f'    done\n'
        '    _log "[FATAL] trap 将自动打包已保存的 checkpoint"\n'
        "    exit 1\n"
        "fi\n\n"
        + (eval_section if test_data or use_fake else no_eval_section)
        + result_section
    )

    fake_label = "（假数据测试）" if use_fake else ""
    description = f"""## LoRA / QLoRA SFT 训练{fake_label}

| 参数 | 值 |
|------|----|
| 模型 | `{model_path}` |
| 训练集 | `{"自动生成假数据 (30条)" if use_fake else train_data}` |
| 测试集 | `{"自动生成假数据 (8条)" if use_fake else (test_data or "未提供，跳过评估")}` |
| 轮数 | {"1 epoch (假数据)" if use_fake else f"{epochs} epochs"} |
| LoRA r/alpha/dropout | `{lora_r}` / `{lora_alpha}` / `{lora_dropout}` |
| 量化 | `{quantization}` |
| Batch Size | `{batch_size} × {gpu_count} GPU` |
| 学习率 | {learning_rate} |
| 输出目录 | `{output_dir}` |
| 内存需求 | {memory_demand} |
| 临时存储 | {ephemeral_storage} |
"""

    submit_job(
        task_name         = f"{'FakeTest' if use_fake else 'LoRA'}-{model_name}",
        description       = description,
        entry_command     = entry_command,
        system_entry_command = """mounts=(
    "/home:/home"
    "/data:/data"
)
export APPTAINER_BIND=$(IFS=,; echo "${mounts[*]}")
export MAGNUS_HOME=/magnus
unset -f nvidia-smi
unset VIRTUAL_ENV SSL_CERT_FILE
""",
        namespace         = "Rise-AGI",
        repo_name         = "OpenFundus",
        gpu_count         = gpu_count,
        gpu_type          = gpu_type,
        cpu_count         = cpu_count,
        memory_demand     = memory_demand,
        ephemeral_storage = ephemeral_storage,
        job_type          = priority,
        execute_action    = execute_action,
        runner            = runner,
        container_image   = container_image,
    )
