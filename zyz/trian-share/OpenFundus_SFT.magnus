# Magnus Blueprint: Qwen 1.5B SFT 训练 + 准确率评估
# 直接粘贴到 Magnus 蓝图编辑器即可，不需要任何 import

# ── 参数类型定义 ──────────────────────────────────────────────

ModelPath = Annotated[str, {
    "label": "模型路径",
    "description": "集群本地路径（优先）或 HuggingFace/ModelScope Hub ID",
    "placeholder": "/data/magnus/models/Qwen2.5-1.5B",
    "allow_empty": False,
}]

TrainData = Annotated[Optional[str], {
    "label": "训练集路径（可选）",
    "description": "留空 = 自动生成30条假数据（用于验证流程）；填路径 = 使用真实数据训练",
    "placeholder": "留空=假数据 / /data/magnus/training_data/train.json",
}]

TestData = Annotated[Optional[str], {
    "label": "测试集路径（可选）",
    "description": "填路径 = 训练完成后自动评估准确率；留空则跳过",
    "placeholder": "/data/magnus/training_data/test.json",
}]

OutputDir = Annotated[str, {
    "label": "输出目录",
    "description": (
        "必须填写 /data/magnus/models/ 下的子目录（持久存储，作业结束后不会消失）。"
        "不能直接填 /home/default/（临时，作业结束即清除）。"
        "示例：/data/magnus/models/qwen-sft-v1"
    ),
    "placeholder": "/data/magnus/models/qwen-sft-v1",
    "allow_empty": False,
}]

Epochs = Annotated[int, {
    "label": "训练轮数",
    "scope": "超参数",
    "min": 1,
    "max": 20,
}]

BatchSize = Annotated[int, {
    "label": "单卡 Batch Size",
    "scope": "超参数",
    "description": "每张 GPU 每步实际处理的样本数。显存不足时首先降低此值，用梯度累积补偿等效 batch。",
    "min": 1,
    "max": 128,
}]

GradAccum = Annotated[int, {
    "label": "梯度累积步数",
    "scope": "超参数",
    "description": "等效全局 batch = 单卡 batch × 梯度累积 × GPU 数。增大此值可在小 batch 下保持训练稳定。",
    "min": 1,
    "max": 32,
}]

LearningRate = Annotated[Optional[float], {
    "label": "学习率",
    "scope": "超参数",
    "min": 1e-6,
    "max": 1e-3,
    "placeholder": "默认 2e-5",
}]

MaxLength = Annotated[int, {
    "label": "最大序列长度（token）",
    "scope": "超参数",
    "min": 128,
    "max": 4096,
}]

SaveSteps = Annotated[int, {
    "label": "Checkpoint 保存间隔（步）",
    "scope": "超参数",
    "min": 50,
    "max": 2000,
}]

GpuCount = Annotated[int, {
    "label": "GPU 数量",
    "min": 1,
    "max": 6,
}]

Priority = Annotated[Literal["A1", "A2", "B1", "B2"], {
    "label": "作业优先级",
    "options": {
        "A1": {"label": "A1 最高", "description": "不可抢占"},
        "A2": {"label": "A2 高（推荐）", "description": "不可抢占"},
        "B1": {"label": "B1 低", "description": "可被 A 类抢占"},
        "B2": {"label": "B2 最低", "description": "可被 A 类抢占"},
    },
}]

Runner = Annotated[Optional[str], {
    "label": "Runner",
    "description": "留空使用默认",
    "placeholder": "leave empty for default",
}]


ResumeFrom = Annotated[Optional[str], {
    "label": "从 Checkpoint 恢复（可选）",
    "description": "填写上次中断的 checkpoint secret（如 25703-word-word-word）或本地路径，留空则从头开始",
    "placeholder": "留空 = 从头训练",
}]

# ── SFT 训练脚本（由蓝图写入集群后执行）────────────────────────

SFT_TRAIN_PY = r'''
import argparse
import json
import os
import time
import torch
import torch.nn.functional as F
from torch.utils.data import Dataset, DataLoader
from transformers import (
    AutoModelForCausalLM,
    AutoTokenizer,
    get_cosine_schedule_with_warmup,
)
from torch.optim import AdamW


def parse_args():
    p = argparse.ArgumentParser(description="Qwen 1.5B SFT on Magnus")
    p.add_argument("--model_path",    type=str, required=True)
    p.add_argument("--train_data",    type=str, required=True)
    p.add_argument("--test_data",     type=str, default=None)
    p.add_argument("--output_dir",    type=str, default="/tmp/sft_output")
    p.add_argument("--epochs",        type=int,   default=3)
    p.add_argument("--batch_size",    type=int,   default=2)
    p.add_argument("--gradient_accumulation_steps", type=int, default=4)
    p.add_argument("--learning_rate", type=float, default=2e-5)
    p.add_argument("--max_length",    type=int,   default=1024)
    p.add_argument("--warmup_ratio",  type=float, default=0.05)
    p.add_argument("--weight_decay",  type=float, default=0.01)
    p.add_argument("--save_steps",    type=int,   default=200)
    p.add_argument("--logging_steps", type=int,   default=10)
    p.add_argument("--resume_from_checkpoint", type=str, default=None)
    return p.parse_args()


def load_json_dataset(path: str) -> list:
    if path.endswith(".parquet"):
        import pandas as pd
        df = pd.read_parquet(path)
        data = df.to_dict(orient="records")
    elif os.path.isdir(path):
        try:
            from datasets import load_from_disk
            ds = load_from_disk(path)
            data = [row for row in ds]
        except Exception:
            import glob
            files = sorted(
                glob.glob(os.path.join(path, "**", "*.json"),  recursive=True) +
                glob.glob(os.path.join(path, "**", "*.jsonl"), recursive=True)
            )
            if not files:
                raise FileNotFoundError(
                    f"目录 {path} 既不是 HuggingFace Dataset，也没有找到任何 .json/.jsonl 文件"
                )
            data = []
            for fp in files:
                print(f"[数据] 读取文件：{fp}")
                with open(fp, "r", encoding="utf-8") as f:
                    raw = f.read().strip()
                if raw.startswith("["):
                    data.extend(json.loads(raw))
                else:
                    data.extend([json.loads(line) for line in raw.splitlines() if line.strip()])
    else:
        with open(path, "r", encoding="utf-8") as f:
            raw = f.read().strip()
        if raw.startswith("["):
            data = json.loads(raw)
        else:
            data = [json.loads(line) for line in raw.splitlines() if line.strip()]
    assert len(data) > 0, f"数据集为空：{path}"
    print(f"[数据] 从 {path} 加载 {len(data)} 条样本")
    return data


class SFTDataset(Dataset):
    def __init__(self, samples, tokenizer, max_length):
        self.samples    = samples
        self.tokenizer  = tokenizer
        self.max_length = max_length

    def __len__(self):
        return len(self.samples)

    def __getitem__(self, idx):
        item = self.samples[idx]
        instruction = item.get("instruction", "")
        extra_input = item.get("input", "")
        output      = item.get("output", "")
        user_content = instruction
        if extra_input:
            user_content += f"\n{extra_input}"
        prompt = (
            "<|im_start|>system\nYou are a helpful assistant.<|im_end|>\n"
            f"<|im_start|>user\n{user_content}<|im_end|>\n"
            "<|im_start|>assistant\n"
        )
        response = f"{output}<|im_end|>"
        prompt_ids   = self.tokenizer.encode(prompt,   add_special_tokens=False)
        response_ids = self.tokenizer.encode(response, add_special_tokens=False)
        input_ids = (prompt_ids + response_ids)[: self.max_length]
        labels    = ([-100] * len(prompt_ids) + response_ids)[: self.max_length]
        return {
            "input_ids": torch.tensor(input_ids, dtype=torch.long),
            "labels":    torch.tensor(labels,    dtype=torch.long),
        }


def collate_fn(batch, pad_id):
    max_len = max(b["input_ids"].size(0) for b in batch)
    input_ids_list, labels_list, attn_list = [], [], []
    for b in batch:
        n   = b["input_ids"].size(0)
        pad = max_len - n
        input_ids_list.append(F.pad(b["input_ids"], (0, pad), value=pad_id))
        labels_list.append(F.pad(b["labels"],    (0, pad), value=-100))
        attn_list.append(torch.cat([torch.ones(n, dtype=torch.long), torch.zeros(pad, dtype=torch.long)]))
    return {
        "input_ids":      torch.stack(input_ids_list),
        "labels":         torch.stack(labels_list),
        "attention_mask": torch.stack(attn_list),
    }


def save_checkpoint(model, tokenizer, output_dir, step, meta):
    ckpt_path = os.path.join(output_dir, f"checkpoint-{step}")
    os.makedirs(ckpt_path, exist_ok=True)
    m = model.module if hasattr(model, "module") else model
    m.save_pretrained(ckpt_path)
    tokenizer.save_pretrained(ckpt_path)
    with open(os.path.join(ckpt_path, "checkpoint_meta.json"), "w", encoding="utf-8") as f:
        json.dump(meta, f, ensure_ascii=False, indent=2)
    print(f"  [Checkpoint] 已保存 step={step} -> {ckpt_path}")


def save_final(model, tokenizer, output_dir, train_log):
    final_path = os.path.join(output_dir, "final")
    os.makedirs(final_path, exist_ok=True)
    m = model.module if hasattr(model, "module") else model
    # max_shard_size="1800MB"：单个分片不超过 1.8GB，满足 GitHub Release 2GB 限制
    m.save_pretrained(final_path, max_shard_size="1800MB")
    tokenizer.save_pretrained(final_path)
    log_path = os.path.join(output_dir, "training_log.json")
    with open(log_path, "w", encoding="utf-8") as f:
        json.dump(train_log, f, ensure_ascii=False, indent=2)
    print(f"[最终模型] 已保存 -> {final_path}")
    print(f"[训练日志] 已保存 -> {log_path}")


@torch.no_grad()
def evaluate(model, dataloader, device):
    model.eval()
    total_loss, total_steps = 0.0, 0
    for batch in dataloader:
        input_ids = batch["input_ids"].to(device)
        labels    = batch["labels"].to(device)
        attn_mask = batch["attention_mask"].to(device)
        outputs   = model(input_ids=input_ids, attention_mask=attn_mask, labels=labels)
        loss = outputs.loss
        if hasattr(loss, "mean"):
            loss = loss.mean()
        total_loss  += loss.item()
        total_steps += 1
    model.train()
    return total_loss / max(total_steps, 1)


def train():
    args   = parse_args()
    device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
    n_gpu  = torch.cuda.device_count()
    os.makedirs(args.output_dir, exist_ok=True)

    print(f"[环境] 设备={device}, GPU 数量={n_gpu}")
    print(f"[配置] epochs={args.epochs}, batch_size={args.batch_size}, lr={args.learning_rate}, max_length={args.max_length}")

    tokenizer = AutoTokenizer.from_pretrained(args.model_path, trust_remote_code=True)
    if tokenizer.pad_token is None:
        tokenizer.pad_token = tokenizer.eos_token

    load_dtype = torch.bfloat16 if torch.cuda.is_available() else torch.float32
    model = AutoModelForCausalLM.from_pretrained(
        args.model_path,
        torch_dtype=load_dtype,
        trust_remote_code=True,
    )
    print(f"[模型] 加载完成，dtype={load_dtype}")
    if torch.cuda.is_available():
        for i in range(torch.cuda.device_count()):
            free, total = torch.cuda.mem_get_info(i)
            print(f"  GPU {i}: 空闲 {free/1e9:.1f}GB / 总计 {total/1e9:.1f}GB")

    start_step = 0
    if args.resume_from_checkpoint:
        ckpt = args.resume_from_checkpoint
        meta_path = os.path.join(ckpt, "checkpoint_meta.json")
        if os.path.exists(meta_path):
            with open(meta_path) as f:
                meta = json.load(f)
            start_step = meta.get("step", 0)
        state = torch.load(os.path.join(ckpt, "pytorch_model.bin"), map_location="cpu") if os.path.exists(os.path.join(ckpt, "pytorch_model.bin")) else None
        if state:
            model.load_state_dict(state, strict=False)
        print(f"[Resume] 从 checkpoint 恢复，start_step={start_step}")

    # 开启梯度检查点：不保存中间激活值，反向时重新计算，显存降低 60-70%
    # 必须在 DataParallel 包装之前调用
    if hasattr(model, "gradient_checkpointing_enable"):
        model.gradient_checkpointing_enable()
        model.config.use_cache = False   # gradient_checkpointing 与 use_cache 不兼容
        print("[模型] gradient_checkpointing 已开启，use_cache 已关闭")

    if n_gpu > 1:
        model = torch.nn.DataParallel(model)
    model.to(device)

    total_params = sum(p.numel() for p in model.parameters()) / 1e9
    eff_batch    = args.batch_size * args.gradient_accumulation_steps * max(n_gpu, 1)
    print(f"[模型] 参数量 {total_params:.2f}B，全量微调")
    print(f"[配置] 实际batch={args.batch_size}/卡，梯度累积={args.gradient_accumulation_steps}步，等效全局batch={eff_batch}")

    pad_id = tokenizer.pad_token_id

    def train_collate(b): return collate_fn(b, pad_id)
    def eval_collate(b):  return collate_fn(b, pad_id)

    train_samples = load_json_dataset(args.train_data)
    train_dataset = SFTDataset(train_samples, tokenizer, args.max_length)
    train_loader  = DataLoader(train_dataset, batch_size=args.batch_size, shuffle=True,  num_workers=0, collate_fn=train_collate)

    eval_loader = None
    if args.test_data and os.path.exists(args.test_data):
        eval_samples = load_json_dataset(args.test_data)
        eval_dataset = SFTDataset(eval_samples, tokenizer, args.max_length)
        eval_loader  = DataLoader(eval_dataset, batch_size=args.batch_size, shuffle=False, num_workers=0, collate_fn=eval_collate)
        print(f"[测试集] 加载 {len(eval_samples)} 条样本")
    else:
        print("[测试集] 未提供，跳过 eval loss 计算")

    optimizer = AdamW(model.parameters(), lr=args.learning_rate, weight_decay=args.weight_decay)
    # total_steps 按 optimizer step 数计算（非 batch 数）
    accum         = args.gradient_accumulation_steps
    steps_per_epoch = (len(train_loader) + accum - 1) // accum
    total_steps   = steps_per_epoch * args.epochs
    warmup_steps  = int(total_steps * args.warmup_ratio)
    scheduler     = get_cosine_schedule_with_warmup(optimizer, warmup_steps, total_steps)

    train_log   = []
    global_step = 0
    optimizer.zero_grad()   # 初始化，后续仅在 optimizer.step() 之后清零
    model.train()

    for epoch in range(1, args.epochs + 1):
        epoch_loss  = 0.0
        epoch_start = time.time()

        for step, batch in enumerate(train_loader, 1):
            input_ids = batch["input_ids"].to(device)
            labels    = batch["labels"].to(device)
            attn_mask = batch["attention_mask"].to(device)

            outputs = model(input_ids=input_ids, attention_mask=attn_mask, labels=labels)
            loss    = outputs.loss
            if n_gpu > 1:
                loss = loss.mean()

            # 梯度累积：loss 按累积步数缩放后反向，梯度在显存中累加
            (loss / accum).backward()
            epoch_loss += loss.item()

            is_update = (step % accum == 0) or (step == len(train_loader))
            if is_update:
                torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)
                optimizer.step()
                scheduler.step()
                optimizer.zero_grad()
                global_step += 1

                if global_step % args.logging_steps == 0:
                    avg_loss = epoch_loss / step
                    lr_now   = scheduler.get_last_lr()[0]
                    print(f"  Epoch {epoch}/{args.epochs} | Step {step}/{len(train_loader)} (global {global_step}) | Loss: {avg_loss:.4f} | LR: {lr_now:.2e}")
                    train_log.append({"global_step": global_step, "epoch": round(epoch - 1 + step / len(train_loader), 3), "train_loss": round(avg_loss, 6), "lr": round(lr_now, 8), "timestamp": time.strftime("%Y-%m-%dT%H:%M:%S")})

                if global_step % args.save_steps == 0:
                    eval_loss = evaluate(model, eval_loader, device) if eval_loader else None
                    save_checkpoint(model, tokenizer, args.output_dir, global_step, meta={"step": global_step, "epoch": round(epoch - 1 + step / len(train_loader), 3), "train_loss": round(epoch_loss / step, 6), "eval_loss": round(eval_loss, 6) if eval_loss is not None else None, "timestamp": time.strftime("%Y-%m-%dT%H:%M:%S")})

        avg_epoch_loss = epoch_loss / len(train_loader)
        elapsed        = time.time() - epoch_start
        eval_loss      = evaluate(model, eval_loader, device) if eval_loader else None
        eval_str = f" | Eval Loss: {eval_loss:.4f}" if eval_loss is not None else ""
        print(f"[Epoch {epoch}/{args.epochs}] Train Loss: {avg_epoch_loss:.4f}{eval_str} | 耗时: {elapsed:.0f}s")
        train_log.append({"global_step": global_step, "epoch": epoch, "train_loss": round(avg_epoch_loss, 6), "eval_loss": round(eval_loss, 6) if eval_loss is not None else None, "elapsed_sec": round(elapsed, 1), "timestamp": time.strftime("%Y-%m-%dT%H:%M:%S")})

    save_final(model, tokenizer, args.output_dir, train_log)

    final_eval_loss = evaluate(model, eval_loader, device) if eval_loader else None
    result = {"status": "success", "final_train_loss": round(train_log[-1]["train_loss"], 6), "final_eval_loss": round(final_eval_loss, 6) if final_eval_loss is not None else None, "total_steps": global_step, "output_dir": args.output_dir}
    print(f"[结果] {json.dumps(result, ensure_ascii=False)}")
    return result


if __name__ == "__main__":
    train()
'''

# ── 准确率评估脚本（训练后在集群执行）────────────────────────
# 注意：此字符串是普通字符串，不是 f-string，{} 均为 Python 代码本身的字符
# 执行前会在顶部注入 model_dir / test_path / out_dir 三个变量

_EVAL_PY = """
import json, os
import torch
from transformers import AutoModelForCausalLM, AutoTokenizer

# model_dir, test_path, out_dir 由外部注入

print("[推理] 加载模型: " + model_dir)
tokenizer = AutoTokenizer.from_pretrained(model_dir, trust_remote_code=True)
if tokenizer.pad_token is None:
    tokenizer.pad_token = tokenizer.eos_token

device = "cuda" if torch.cuda.is_available() else "cpu"
model = AutoModelForCausalLM.from_pretrained(
    model_dir,
    dtype=torch.bfloat16 if device == "cuda" else torch.float32,
    device_map="auto" if device == "cuda" else None,
    trust_remote_code=True,
)
if device == "cpu":
    model = model.to(device)
model.eval()
print("[推理] 模型加载完成，设备: " + device)

with open(test_path, "r", encoding="utf-8") as fh:
    raw = fh.read().strip()
samples = json.loads(raw) if raw.startswith("[") else [json.loads(ln) for ln in raw.splitlines() if ln.strip()]
print("[推理] 测试集共 " + str(len(samples)) + " 条")

results = []

for i, sample in enumerate(samples):
    instruction = sample.get("instruction", "")
    extra       = sample.get("input", "")
    gt_out      = sample.get("output", "")

    user_content = instruction + ("\\n" + extra if extra else "")
    prompt = (
        "<|im_start|>system\\nYou are a helpful assistant.<|im_end|>\\n"
        + "<|im_start|>user\\n" + user_content + "<|im_end|>\\n"
        + "<|im_start|>assistant\\n"
    )

    inputs = tokenizer(prompt, return_tensors="pt", truncation=True, max_length=1024).to(device)
    with torch.no_grad():
        out_ids = model.generate(
            **inputs,
            max_new_tokens=512,
            do_sample=False,
            pad_token_id=tokenizer.eos_token_id,
        )
    new_ids  = out_ids[0][inputs["input_ids"].shape[1]:]
    response = tokenizer.decode(new_ids, skip_special_tokens=True).strip()

    results.append({
        "id":            sample.get("id", i),
        "question":      user_content,
        "gt_output":     gt_out,
        "full_response": response,
    })

    if (i + 1) % 10 == 0 or (i + 1) == len(samples):
        print("  进度 %d/%d" % (i + 1, len(samples)))

eval_dir = os.path.join(out_dir, "eval")
os.makedirs(eval_dir, exist_ok=True)

eval_path = os.path.join(eval_dir, "eval_results.json")
with open(eval_path, "w", encoding="utf-8") as fh:
    json.dump(results, fh, ensure_ascii=False, indent=2)
print("[推理] 结果已保存: " + eval_path + "  共 %d 条" % len(results))
"""


# ── Blueprint 主函数 ─────────────────────────────────────────

def blueprint(
    model_path:       ModelPath       = "/data/magnus/models/Qwen2.5-1.5B",
    train_data:       TrainData       = None,
    test_data:        TestData        = None,
    output_dir:       OutputDir       = "/data/magnus/models/qwen-sft-v1",
    epochs:           Epochs          = 3,
    batch_size:       BatchSize       = 2,
    grad_accum:       GradAccum       = 4,
    learning_rate:    LearningRate    = None,
    max_length:       MaxLength       = 1024,
    save_steps:       SaveSteps       = 200,
    gpu_count:        GpuCount        = 6,
    priority:         Priority        = "A2",
    runner:           Runner          = None,
    resume_from:      ResumeFrom      = None,
):
    lr = learning_rate if learning_rate is not None else 2e-5
    use_fake = not train_data

    ms_model_id = model_path[0].lower() + model_path[1:]

    # ── Resume 设置 ───────────────────────────────────────────
    def _is_magnus_secret(s):
        s = s.strip()
        if s.startswith("magnus-secret:"):
            return True
        parts = s.split("-")
        return len(parts) == 4 and parts[0].isdigit()

    if not resume_from:
        resume_setup = 'RESUME_ARG=""'
    elif _is_magnus_secret(resume_from.strip()):
        token = resume_from.strip()
        resume_setup = (
            'echo "=== [Resume] 从 Magnus 下载 checkpoint ==="\n'
            f'magnus receive {token} -o /tmp/resume_ckpt\n'
            'RESUME_ARG="--resume_from_checkpoint /tmp/resume_ckpt"\n'
            'echo "[Resume] checkpoint 已下载到 /tmp/resume_ckpt"'
        )
    else:
        resume_setup = f'RESUME_ARG="--resume_from_checkpoint {resume_from.strip()}"'

    # ── 模型加载 ──────────────────────────────────────────────
    model_setup = f"""
echo "=== 加载模型 ==="
if [ -f "{model_path}/config.json" ]; then
    ACTUAL_MODEL_PATH="{model_path}"
    echo "[模型] 使用本地路径: $ACTUAL_MODEL_PATH"
else
    echo "[模型] 本地路径不存在，尝试 ModelScope: {ms_model_id}"
    pip install -q modelscope
    if python3 -c "
from modelscope import snapshot_download
path = snapshot_download('{ms_model_id}', cache_dir='/tmp/models')
print(path)
" > /tmp/ms_path.txt 2>/tmp/ms_err.txt; then
        ACTUAL_MODEL_PATH=$(tail -1 /tmp/ms_path.txt)
        echo "[模型] ModelScope 完成: $ACTUAL_MODEL_PATH"
    else
        echo "[模型] ModelScope 失败，尝试 HuggingFace..."
        cat /tmp/ms_err.txt
        if python3 -c "
from transformers import AutoModelForCausalLM, AutoTokenizer
AutoTokenizer.from_pretrained('{model_path}', trust_remote_code=True).save_pretrained('/tmp/qwen_model')
AutoModelForCausalLM.from_pretrained('{model_path}', trust_remote_code=True).save_pretrained('/tmp/qwen_model')
print('HuggingFace 下载完成')
" 2>/tmp/hf_err.txt; then
            ACTUAL_MODEL_PATH=/tmp/qwen_model
        else
            cat /tmp/hf_err.txt
            echo "[FATAL] 无法加载模型"
            exit 1
        fi
    fi
fi
"""

    # ── 数据设置 ──────────────────────────────────────────────
    if use_fake:
        data_setup = """
echo "=== 生成假数据（30条物理题）==="
python3 -c "
import json
fake_train = [{'instruction': f'物理题{i}：一个质量为{i+1}kg的物体受到{(i+1)*5}N合力，求加速度。', 'output': f'答案：5 m/s²\\n\\n解答：根据牛顿第二定律 F=ma，加速度 a = F/m = {(i+1)*5}/{i+1} = 5 m/s²。'} for i in range(30)]
fake_test  = [{'instruction': f'测试题{i}：求速度为{i+1}m/s、质量为2kg物体的动能。', 'output': f'答案：{(i+1)**2} J\\n\\n解答：动能 Ek = 0.5mv² = 0.5×2×{(i+1)**2} = {(i+1)**2} J。'} for i in range(8)]
with open('/tmp/fake_train.json', 'w') as f: json.dump(fake_train, f, ensure_ascii=False)
with open('/tmp/fake_test.json',  'w') as f: json.dump(fake_test,  f, ensure_ascii=False)
print('假数据生成完成：train=30条，test=8条')
"
TRAIN_DATA_PATH=/tmp/fake_train.json
TEST_DATA_PATH=/tmp/fake_test.json
TRAIN_EPOCHS=1
TRAIN_BATCH=2
TRAIN_ACCUM=4
TRAIN_MAXLEN=256
TRAIN_SAVE=20
TRAIN_LOG=5
"""
    else:
        data_setup = f"""
TRAIN_DATA_PATH="{train_data}"
TEST_DATA_PATH="{test_data if test_data else ''}"
TRAIN_EPOCHS={epochs}
TRAIN_BATCH={batch_size}
TRAIN_ACCUM={grad_accum}
TRAIN_MAXLEN={max_length}
TRAIN_SAVE={save_steps}
TRAIN_LOG=10
"""

    # ── 评估脚本（写入临时文件，避免 shell 解析 Python 括号） ──
    # 路径在 blueprint 函数执行时已确定，直接插值，不依赖 shell 变量展开
    resolved_test = test_data if test_data else "/tmp/fake_test.json"
    eval_header = f"""
echo "=== [5/5] 测试集推理（生成原始回答，不计算准确率）==="
cat > /tmp/eval_accuracy.py << 'PYEOF'
model_dir = "{output_dir}/final"
test_path  = "{resolved_test}"
out_dir    = "{output_dir}"
"""
    # _EVAL_PY 是普通字符串，直接拼接，不经过 f-string 解析
    eval_custody = (
        f'\necho "=== 上传推理结果 ==="\n'
        f'python3 << \'EVALEOF\'\n'
        f'import subprocess, sys\n'
        f'subprocess.run([sys.executable, "-m", "pip", "install", "-q", "magnus-sdk"], check=True)\n'
        f'import magnus\n'
        f'secret = magnus.custody_file("{output_dir}/eval/eval_results.json", expire_minutes=1440, timeout=60.0)\n'
        f'print("")\n'
        f'print("===== 推理结果下载命令 =====")\n'
        f'print(f"magnus receive {{secret}} -o ./eval_review/eval_results.json")\n'
        f'print("===========================")\n'
        f'EVALEOF\n'
    )
    eval_section = eval_header + _EVAL_PY + "\nPYEOF\npython3 /tmp/eval_accuracy.py\n" + eval_custody

    no_eval_section = 'echo "[5/5] 未提供测试集，跳过准确率评估"\n'


    # ── 汇总结果（成功路径）────────────────────────────────────
    result_section = f"""
python3 -c "
import json, os
log_path  = '{output_dir}/training_log.json'
eval_path = '{output_dir}/eval/eval_results.json'
last = {{}}
if os.path.exists(log_path):
    with open(log_path) as f:
        log = json.load(f)
    last = log[-1] if log else {{}}
eval_count = 0
if os.path.exists(eval_path):
    with open(eval_path) as f:
        ev = json.load(f)
    eval_count = len(ev) if isinstance(ev, list) else 0
print(json.dumps({{
    'status':           'success',
    'server_path':      '{output_dir}',
    'final_train_loss': last.get('train_loss'),
    'final_eval_loss':  last.get('eval_loss'),
    'eval_samples':     eval_count,
}}, ensure_ascii=False))
" > "$MAGNUS_RESULT"
"""

    # ── 组装完整 entry_command ────────────────────────────────
    entry_command = (
        "set -e\n"
        "export PYTHONDONTWRITEBYTECODE=1\n"
        "export PYTHONPYCACHEPREFIX=/tmp/.pycache\n\n"

        f'_on_exit() {{\n'
        f'    echo ""\n'
        f'    echo "=== [退出] 上传训练日志 ==="\n'
        f'    LOG_PATH="{output_dir}/training_log.json"\n'
        f'    if [ ! -f "$LOG_PATH" ]; then\n'
        f'        echo "[警告] 未找到训练日志: $LOG_PATH"\n'
        f'        return\n'
        f'    fi\n'
        f'    python3 << \'TRAPEOF\'\n'
        f'import subprocess, sys\n'
        f'subprocess.run([sys.executable, "-m", "pip", "install", "-q", "magnus-sdk"], check=True)\n'
        f'import magnus\n'
        f'secret = magnus.custody_file("{output_dir}/training_log.json", expire_minutes=1440, timeout=60.0)\n'
        f'print("")\n'
        f'print("===== 训练日志下载命令 =====")\n'
        f'print(f"magnus receive {{secret}} -o ./sft/training_log.json")\n'
        f'print("===========================")\n'
        f'TRAPEOF\n'
        f'}}\n'
        f'trap _on_exit EXIT\n\n'

        f'echo "=== [0/5] 检查输出目录 ==="\n'
        f'mkdir -p "{output_dir}" || {{\n'
        f'    echo "[FATAL] 无法创建输出目录 {output_dir}"\n'
        f'    echo "  原因：/data/magnus/ 根目录无写权限，请确保父目录已存在"\n'
        f'    echo "  正确示例：/data/magnus/models/qwen-sft-v1（models/ 已存在）"\n'
        f'    echo "  错误示例：/data/magnus/mydir/qwen（mydir/ 不存在）"\n'
        f'    exit 1\n'
        f'}}\n'
        f'echo "输出目录可用: {output_dir}"\n\n'

        f'echo "=== [1/5] 环境信息 ==="\n'
        "nvidia-smi\n"
        "python3 --version\n\n"
        f'echo "=== [2/5] 检查依赖 ==="\n'
        "python3 - << 'DEPEOF'\n"
        "import sys, subprocess\n"
        "\n"
        "def ok(pkg, min_ver=None):\n"
        "    try:\n"
        "        m = __import__(pkg)\n"
        "        if min_ver:\n"
        "            cur = tuple(int(x) for x in m.__version__.split('.')[:2])\n"
        "            req = tuple(int(x) for x in min_ver.split('.')[:2])\n"
        "            return cur >= req\n"
        "        return True\n"
        "    except Exception:\n"
        "        return False\n"
        "\n"
        "checks = [\n"
        "    ('transformers>=4.45', 'transformers', '4.45'),\n"
        "    ('datasets',           'datasets',     None),\n"
        "    ('accelerate',         'accelerate',   None),\n"
        "    ('pandas',             'pandas',       None),\n"
        "]\n"
        "need = []\n"
        "for spec, pkg, ver in checks:\n"
        "    if ok(pkg, ver):\n"
        "        m = __import__(pkg)\n"
        "        print(f'  [就绪] {pkg} {getattr(m, \"__version__\", \"\")}')\n"
        "    else:\n"
        "        need.append(spec)\n"
        "        print(f'  [缺失] {spec}')\n"
        "try:\n"
        "    import magnus; print('  [就绪] magnus (预装 SDK)')\n"
        "except ImportError:\n"
        "    print('  [警告] magnus SDK 未找到，custody 上传将失败')\n"
        "\n"
        "if need:\n"
        "    print('安装缺失依赖:', ' '.join(need))\n"
        "    r = subprocess.run([sys.executable, '-m', 'pip', 'install', '-q'] + need)\n"
        "    sys.exit(r.returncode)\n"
        "else:\n"
        "    print('所有依赖已就绪，跳过 pip install')\n"
        "DEPEOF\n"
        "python3 -c \"import torch; print('[环境] torch', torch.__version__, '| CUDA', torch.version.cuda, '| GPU', torch.cuda.device_count(), '张')\"\n\n"
        f'echo "=== [3/5] 准备模型和数据 ==="\n'
        + model_setup
        + data_setup
        + f'\necho "=== [4/5] 开始 SFT 训练 ==="\n'
        + resume_setup + "\n\n"
        "cat > /tmp/sft_train.py << 'SFEOF'\n"
        + SFT_TRAIN_PY
        + "\nSFEOF\n\n"
        # 训练失败时不再 exit 1，让脚本走到末尾触发 trap
        "TRAIN_OK=0\n"
        "if python3 /tmp/sft_train.py \\\n"
        f'    --model_path    "$ACTUAL_MODEL_PATH" \\\n'
        f'    --train_data    "$TRAIN_DATA_PATH" \\\n'
        f'    --test_data     "$TEST_DATA_PATH" \\\n'
        f'    --output_dir    "{output_dir}" \\\n'
        f'    --epochs        $TRAIN_EPOCHS \\\n'
        f'    --batch_size    $TRAIN_BATCH \\\n'
        f'    --gradient_accumulation_steps $TRAIN_ACCUM \\\n'
        f'    --learning_rate {lr} \\\n'
        f'    --max_length    $TRAIN_MAXLEN \\\n'
        f'    --save_steps    $TRAIN_SAVE \\\n'
        f'    --logging_steps $TRAIN_LOG \\\n'
        f'    $RESUME_ARG; then\n'
        f'    TRAIN_OK=1\n'
        f'    echo "=== 训练完成 ==="\n'
        "else\n"
        '    echo "[FATAL] 训练异常退出，trap 将自动打包已保存的 checkpoint"\n'
        "    exit 1\n"
        "fi\n\n"
        + (eval_section if test_data or use_fake else no_eval_section)
        + result_section
    )

    fake_label = "（假数据测试）" if use_fake else ""
    description = f"""## Qwen SFT 训练 + 准确率评估{fake_label}

| 参数 | 值 |
|------|----|
| 模型 | `{model_path}` |
| 训练集 | `{"自动生成假数据 (30条)" if use_fake else train_data}` |
| 测试集 | `{"自动生成假数据 (8条)" if use_fake else (test_data or "未提供，跳过评估")}` |
| 轮数 | {"1 epoch (假数据)" if use_fake else f"{epochs} epochs"} |
| Batch Size | `{"4" if use_fake else batch_size} × {gpu_count} GPU` |
| 学习率 | {lr} |
| 输出目录 | `{output_dir}` |
"""

    submit_job(
        task_name     = f"{'FakeTest' if use_fake else 'SFT'}-{model_path.split('/')[-1]}",
        description   = description,
        entry_command = entry_command,
        namespace     = "Rise-AGI",
        repo_name     = "OpenFundus",
        gpu_count     = gpu_count,
        gpu_type      = "a100",
        job_type      = getattr(JobType, priority),
        runner        = runner,
    )
